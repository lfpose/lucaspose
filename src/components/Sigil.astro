---
type Variant = 'eye' | 'chess' | 'compass' | 'mail' | 'hourglass' | 'work' | 'book' | 'mountain' | 'projects';
const { size = 28, variant = 'eye' as Variant } = Astro.props;
---

<svg viewBox="-100 -100 200 200" width={size} height={size} class="sigil" aria-hidden="true">
  <g filter="url(#woodcut)" stroke="currentColor" fill="none" stroke-width="2.4" stroke-linecap="round">

    {variant === 'eye' && (
      <>
        <g class="sg-cw">
          <g fill="currentColor" stroke="none">
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(45)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(90)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(135)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(180)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(225)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(270)" />
            <path d="M -7 -86 L 0 -62 L 7 -86 Z" transform="rotate(315)" />
          </g>
          <g fill="currentColor" stroke="none">
            <circle cx="0" cy="-72" r="2.4" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(30)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(60)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(90)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(120)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(150)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(180)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(210)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(240)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(270)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(300)" />
            <circle cx="0" cy="-72" r="2.4" transform="rotate(330)" />
          </g>
        </g>
        <g class="sg-ccw">
          <circle r="44" stroke-dasharray="6 5" />
          <path d="M 0 -28 L 5 0 L 0 28 L -5 0 Z" fill="currentColor" stroke="none" />
          <path d="M -28 0 L 0 5 L 28 0 L 0 -5 Z" fill="currentColor" stroke="none" />
        </g>
        <g class="sg-pulse">
          <circle r="13" fill="currentColor" stroke="none" />
          <circle r="6" style="fill: var(--bg)" stroke="none" />
          <circle r="2" fill="currentColor" stroke="none" />
        </g>
      </>
    )}

    {variant === 'chess' && (
      <>
        <g class="sg-cw">
          {/* alternating filled/empty squares — chessboard ring */}
          <rect x="-7" y="-82" width="14" height="14" fill="currentColor" stroke="none" />
          <rect x="-7" y="-82" width="14" height="14" stroke="currentColor" stroke-width="1.8" fill="none" transform="rotate(45)" />
          <rect x="-7" y="-82" width="14" height="14" fill="currentColor" stroke="none" transform="rotate(90)" />
          <rect x="-7" y="-82" width="14" height="14" stroke="currentColor" stroke-width="1.8" fill="none" transform="rotate(135)" />
          <rect x="-7" y="-82" width="14" height="14" fill="currentColor" stroke="none" transform="rotate(180)" />
          <rect x="-7" y="-82" width="14" height="14" stroke="currentColor" stroke-width="1.8" fill="none" transform="rotate(225)" />
          <rect x="-7" y="-82" width="14" height="14" fill="currentColor" stroke="none" transform="rotate(270)" />
          <rect x="-7" y="-82" width="14" height="14" stroke="currentColor" stroke-width="1.8" fill="none" transform="rotate(315)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
          {/* 4 knight L-moves */}
          <path d="M 0 -40 L 0 -22 L 16 -22" stroke-width="2.2" />
          <path d="M 0 -40 L 0 -22 L 16 -22" stroke-width="2.2" transform="rotate(90)" />
          <path d="M 0 -40 L 0 -22 L 16 -22" stroke-width="2.2" transform="rotate(180)" />
          <path d="M 0 -40 L 0 -22 L 16 -22" stroke-width="2.2" transform="rotate(270)" />
        </g>
        <g class="sg-pulse">
          {/* 2x2 mini chessboard */}
          <rect x="-13" y="-13" width="13" height="13" fill="currentColor" stroke="none" />
          <rect x="0"   y="0"   width="13" height="13" fill="currentColor" stroke="none" />
          <rect x="0"   y="-13" width="13" height="13" stroke="currentColor" stroke-width="1.6" fill="none" />
          <rect x="-13" y="0"   width="13" height="13" stroke="currentColor" stroke-width="1.6" fill="none" />
        </g>
      </>
    )}

    {variant === 'compass' && (
      <>
        <g class="sg-cw">
          {/* 4 large arrowheads at N/E/S/W */}
          <path d="M -10 -86 L 0 -68 L 10 -86 Z" fill="currentColor" stroke="none" />
          <path d="M -10 -86 L 0 -68 L 10 -86 Z" fill="currentColor" stroke="none" transform="rotate(90)" />
          <path d="M -10 -86 L 0 -68 L 10 -86 Z" fill="currentColor" stroke="none" transform="rotate(180)" />
          <path d="M -10 -86 L 0 -68 L 10 -86 Z" fill="currentColor" stroke="none" transform="rotate(270)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
          {/* 4 small ticks at NE/SE/SW/NW */}
          <line x1="0" y1="-32" x2="0" y2="-22" stroke-width="2.2" transform="rotate(45)" />
          <line x1="0" y1="-32" x2="0" y2="-22" stroke-width="2.2" transform="rotate(135)" />
          <line x1="0" y1="-32" x2="0" y2="-22" stroke-width="2.2" transform="rotate(225)" />
          <line x1="0" y1="-32" x2="0" y2="-22" stroke-width="2.2" transform="rotate(315)" />
        </g>
        <g class="sg-pulse">
          {/* compass needle: long N-S, short E-W, with North arrowhead */}
          <line x1="0" y1="-22" x2="0" y2="22" stroke-width="2.6" />
          <line x1="-12" y1="0" x2="12" y2="0" stroke-width="2.2" />
          <path d="M -5 -16 L 0 -24 L 5 -16 Z" fill="currentColor" stroke="none" />
        </g>
      </>
    )}

    {variant === 'mail' && (
      <>
        <g class="sg-cw">
          {/* 8 short rays radiating out */}
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(45)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(90)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(135)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(180)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(225)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(270)" />
          <line x1="0" y1="-72" x2="0" y2="-86" stroke-width="2.2" transform="rotate(315)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
        </g>
        <g class="sg-pulse">
          {/* envelope */}
          <rect x="-22" y="-14" width="44" height="28" stroke-width="2.4" />
          <path d="M -22 -14 L 0 4 L 22 -14" stroke-width="2.2" />
        </g>
      </>
    )}

    {variant === 'hourglass' && (
      <>
        <g class="sg-cw">
          {/* 12 clock-position ticks */}
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(30)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(60)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(90)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(120)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(150)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(180)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(210)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(240)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(270)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(300)" />
          <line x1="0" y1="-86" x2="0" y2="-72" stroke-width="2.2" transform="rotate(330)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
        </g>
        <g class="sg-pulse">
          {/* hourglass: two triangles meeting at center */}
          <path d="M -18 -22 L 18 -22 L 0 0 L 18 22 L -18 22 L 0 0 Z" stroke-width="2.4" />
          <line x1="-22" y1="-22" x2="22" y2="-22" stroke-width="2.4" />
          <line x1="-22" y1="22" x2="22" y2="22" stroke-width="2.4" />
        </g>
      </>
    )}

    {variant === 'work' && (
      <>
        <g class="sg-cw">
          {/* 12 gear teeth — small rectangles around the rim */}
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(30)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(60)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(90)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(120)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(150)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(180)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(210)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(240)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(270)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(300)" />
          <rect x="-3.5" y="-90" width="7" height="14" fill="currentColor" stroke="none" transform="rotate(330)" />
          <circle r="74" stroke-width="2.2" />
        </g>
        <g class="sg-ccw">
          <circle r="44" stroke-dasharray="5 4" />
        </g>
        <g class="sg-pulse">
          {/* central inner cog: octagon outline + dot */}
          <path d="M -14 0 L -10 -10 L 0 -14 L 10 -10 L 14 0 L 10 10 L 0 14 L -10 10 Z" stroke-width="2.4" />
          <circle r="4" fill="currentColor" stroke="none" />
        </g>
      </>
    )}

    {variant === 'book' && (
      <>
        <g class="sg-cw">
          {/* 8 tall flame thorns */}
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(45)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(90)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(135)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(180)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(225)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(270)" />
          <path d="M -5 -90 L 0 -58 L 5 -90 Z" fill="currentColor" stroke="none" transform="rotate(315)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
        </g>
        <g class="sg-pulse">
          {/* open book viewed from above */}
          <path d="M -22 -10 L -2 -14 L -2 14 L -22 10 Z" stroke-width="2.2" />
          <path d="M  22 -10 L  2 -14 L  2 14 L  22 10 Z" stroke-width="2.2" />
          <line x1="-18" y1="-6" x2="-6" y2="-9" stroke-width="1.4" />
          <line x1="-18" y1="0"  x2="-6" y2="-3" stroke-width="1.4" />
          <line x1=" 18" y1="-6" x2=" 6" y2="-9" stroke-width="1.4" />
          <line x1=" 18" y1="0"  x2=" 6" y2="-3" stroke-width="1.4" />
        </g>
      </>
    )}

    {variant === 'mountain' && (
      <>
        <g class="sg-cw">
          {/* 6 small triangle peaks (hexagonal) */}
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" />
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" transform="rotate(60)" />
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" transform="rotate(120)" />
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" transform="rotate(180)" />
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" transform="rotate(240)" />
          <path d="M -7 -84 L 0 -70 L 7 -84 Z" fill="currentColor" stroke="none" transform="rotate(300)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
          <path d="M 0 -28 L 5 0 L 0 28 L -5 0 Z" fill="currentColor" stroke="none" />
        </g>
        <g class="sg-pulse">
          {/* mountain peak with ridge */}
          <path d="M -22 18 L 0 -22 L 22 18 Z" stroke-width="2.4" />
          <path d="M -10 8 L -2 -2 L 8 10" stroke-width="1.6" />
          {/* tiny sun above peak */}
          <circle cx="0" cy="-30" r="3" fill="currentColor" stroke="none" />
        </g>
      </>
    )}

    {variant === 'projects' && (
      <>
        <g class="sg-cw">
          {/* 8 building blocks around the rim */}
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(45)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(90)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(135)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(180)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(225)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(270)" />
          <rect x="-6" y="-84" width="12" height="12" fill="currentColor" stroke="none" transform="rotate(315)" />
        </g>
        <g class="sg-ccw">
          <circle r="46" stroke-dasharray="6 5" />
          {/* scaffold cross */}
          <line x1="-32" y1="-32" x2="32" y2="32" stroke-width="1.6" />
          <line x1="-32" y1="32" x2="32" y2="-32" stroke-width="1.6" />
        </g>
        <g class="sg-pulse">
          {/* stacked tower of 3 blocks */}
          <rect x="-18" y="-16" width="36" height="9" fill="currentColor" stroke="none" />
          <rect x="-13" y="-4"  width="26" height="9" fill="currentColor" stroke="none" />
          <rect x="-8"  y="8"   width="16" height="9" fill="currentColor" stroke="none" />
        </g>
      </>
    )}

  </g>
</svg>

<style>
  .sigil {
    display: inline-block;
    flex: 0 0 auto;
    color: currentColor;
    vertical-align: middle;
  }
  .sg-cw,
  .sg-ccw,
  .sg-pulse {
    transform-origin: 50% 50%;
    transform-box: fill-box;
  }
  .sg-cw    { animation: sg-cw    42s linear infinite; }
  .sg-ccw   { animation: sg-ccw   55s linear infinite; }
  .sg-pulse { animation: sg-pulse 4.5s ease-in-out infinite; }

  @keyframes sg-cw    { to { transform: rotate(360deg); } }
  @keyframes sg-ccw   { to { transform: rotate(-360deg); } }
  @keyframes sg-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sg-cw, .sg-ccw, .sg-pulse { animation: none; }
  }
</style>
