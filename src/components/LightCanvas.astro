---
---

<!-- Labyrinth grid background -->
<canvas id="maze-bg" aria-hidden="true"></canvas>

<!-- HDMI glitch overlay -->
<canvas id="glitch-canvas" aria-hidden="true"></canvas>

<!-- Film grain overlay -->
<canvas id="grain-canvas" aria-hidden="true"></canvas>

<style>
  /* ── Maze canvas — dark mode only ────────────── */
  #maze-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Glitch + grain ──────────────────────────── */
  #glitch-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 2;
  }

  #grain-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 150;
  }
  :root[data-theme='dark'] #grain-canvas {
    opacity: 0.035;
    mix-blend-mode: overlay;
  }
  :root:not([data-theme='dark']) #grain-canvas {
    opacity: 0.04;
    mix-blend-mode: multiply;
  }
</style>

<script>
  function isDark(): boolean {
    return document.documentElement.getAttribute('data-theme') === 'dark';
  }

  // ── Labyrinth grid ───────────────────────────
  const cvs = document.getElementById('maze-bg') as HTMLCanvasElement;
  const ctx = cvs.getContext('2d')!;

  const CELL = 52;        // grid spacing
  const R_CIRCLE = 4.5;   // hollow circle radius
  const R_DOT = 1.5;      // filled dot radius
  const GAP = 9;          // line endpoint distance from node center
  const WALKERS = 10;
  const DECAY = 0.992;    // edge fade per tick

  let cols = 0, rows = 0;
  let edgesH: Float32Array; // horizontal edges: edgesH[r*cols + c] = edge from (r,c) to (r,c+1)
  let edgesV: Float32Array; // vertical:           edgesV[r*cols + c] = edge from (r,c) to (r+1,c)

  // Mouse — smoothed so walker bias / glow don't feel jumpy
  let mouseTargetX = -9999, mouseTargetY = -9999;
  let mouseX = -9999, mouseY = -9999;
  let lastSpawnTime = 0;
  window.addEventListener('mousemove', (e) => {
    mouseTargetX = e.clientX + window.scrollX;
    mouseTargetY = e.clientY + window.scrollY;
    if (mouseX < 0) { mouseX = mouseTargetX; mouseY = mouseTargetY; }
    // Spawn a walker at cursor occasionally — visible mouse-move feedback
    const now = performance.now();
    if (now - lastSpawnTime > 220 && cols > 0) {
      const r = Math.max(0, Math.min(rows - 1, Math.round(mouseTargetY / CELL)));
      const c = Math.max(0, Math.min(cols - 1, Math.round(mouseTargetX / CELL)));
      walkers.push({ r, c, lastDir: Math.floor(Math.random() * 4), life: 50 });
      lastSpawnTime = now;
    }
  });

  function resize() {
    cvs.width  = window.innerWidth;
    cvs.height = Math.max(
      document.documentElement.scrollHeight,
      document.body.scrollHeight,
      document.body.offsetHeight,
      window.innerHeight,
    );
    cols = Math.ceil(cvs.width  / CELL) + 1;
    rows = Math.ceil(cvs.height / CELL) + 1;
    edgesH = new Float32Array(rows * cols);
    edgesV = new Float32Array(rows * cols);
  }

  // Walkers — biased random walk to make recognisable corridors
  type Walker = { r: number; c: number; lastDir: number; life: number };
  const walkers: Walker[] = [];

  function spawnWalker(): Walker {
    return {
      r: Math.floor(Math.random() * rows),
      c: Math.floor(Math.random() * cols),
      lastDir: Math.floor(Math.random() * 4),
      life: 80 + Math.floor(Math.random() * 80),
    };
  }

  // 0=up, 1=right, 2=down, 3=left
  const DR = [-1, 0, 1, 0];
  const DC = [0, 1, 0, -1];

  function stepWalker(w: Walker) {
    let dir;
    // 35% bias toward mouse if it's been seen; otherwise default behaviour
    if (mouseX > 0 && Math.random() < 0.35) {
      const wx = w.c * CELL, wy = w.r * CELL;
      const dx = mouseX - wx, dy = mouseY - wy;
      if (Math.abs(dx) > Math.abs(dy)) dir = dx > 0 ? 1 : 3;
      else                              dir = dy > 0 ? 2 : 0;
    } else if (Math.random() < 0.6) {
      dir = w.lastDir;
    } else {
      dir = (w.lastDir + (Math.random() < 0.5 ? 1 : 3)) % 4;
    }
    const nr = w.r + DR[dir];
    const nc = w.c + DC[dir];
    if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
      // bounce: pick a new direction next tick
      w.lastDir = (w.lastDir + 2) % 4;
      return;
    }
    // Light up the edge between (w.r, w.c) and (nr, nc)
    if (dir === 1)      edgesH[w.r * cols + w.c] = 1;
    else if (dir === 3) edgesH[w.r * cols + nc]  = 1;
    else if (dir === 2) edgesV[w.r * cols + w.c] = 1;
    else                edgesV[nr  * cols + w.c] = 1;
    w.r = nr; w.c = nc;
    w.lastDir = dir;
    w.life--;
  }

  function updateWalkers() {
    for (let i = walkers.length - 1; i >= 0; i--) {
      stepWalker(walkers[i]);
      if (walkers[i].life <= 0) walkers.splice(i, 1);
    }
    while (walkers.length < WALKERS) walkers.push(spawnWalker());
  }

  function decay() {
    for (let i = 0; i < edgesH.length; i++) {
      edgesH[i] *= DECAY;
      edgesV[i] *= DECAY;
    }
  }

  // Ink colour is theme-aware: red for dark, forest-green for light (monochrome each)
  function ink(): string {
    return isDark() ? '220,40,50' : '14,36,23';
  }
  const GLOW_R = 260; // halo radius for mouse glow

  function nodeGlow(x: number, y: number): number {
    if (mouseX < 0) return 0;
    const dx = x - mouseX, dy = y - mouseY;
    const d = Math.sqrt(dx*dx + dy*dy);
    if (d > GLOW_R) return 0;
    const t = 1 - d / GLOW_R;
    return t * t * 0.55; // soft falloff, max +0.55
  }

  // Per-theme subtlety: dark stays a bit more present, light is whisper-quiet
  function subtle(): number { return isDark() ? 0.85 : 0.35; }

  // Deterministic per-edge bow offset for curvature — gives the maze a hand-drawn feel
  const BOW = 5;
  function bowH(r: number, c: number): number {
    return Math.sin(r * 12.9898 + c * 78.233) * BOW;
  }
  function bowV(r: number, c: number): number {
    return Math.sin(r * 39.346 + c * 11.135) * BOW;
  }

  function render() {
    ctx.clearRect(0, 0, cvs.width, cvs.height);
    const RGB = ink();
    const S = subtle();

    // Nodes — hollow circle + filled dot. Brighter near cursor.
    ctx.lineWidth = 1;
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const x = c * CELL, y = r * CELL;
        const g = nodeGlow(x, y);
        ctx.strokeStyle = `rgba(${RGB},${(0.16 + g * 0.4) * S})`;
        ctx.beginPath();
        ctx.arc(x, y, R_CIRCLE, 0, Math.PI * 2);
        ctx.stroke();
        ctx.fillStyle = `rgba(${RGB},${(0.45 + g * 0.5) * S})`;
        ctx.beginPath();
        ctx.arc(x, y, R_DOT, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Edges — gently curved, gentle flicker, glow boost near cursor
    ctx.lineCap = 'round';
    ctx.lineWidth = 1.4;
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const x = c * CELL, y = r * CELL;
        const h = edgesH[r * cols + c];
        if (h > 0.04 && c < cols - 1) {
          const g = nodeGlow(x + CELL / 2, y);
          const fl = 0.7 + Math.random() * 0.3; // gentler flicker (0.7 - 1.0)
          ctx.strokeStyle = `rgba(${RGB},${Math.min(1, (h * 0.85 * fl + g * 0.4) * S)})`;
          ctx.beginPath();
          ctx.moveTo(x + GAP, y);
          ctx.quadraticCurveTo(x + CELL / 2, y + bowH(r, c), x + CELL - GAP, y);
          ctx.stroke();
        }
        const v = edgesV[r * cols + c];
        if (v > 0.04 && r < rows - 1) {
          const g = nodeGlow(x, y + CELL / 2);
          const fl = 0.7 + Math.random() * 0.3;
          ctx.strokeStyle = `rgba(${RGB},${Math.min(1, (v * 0.85 * fl + g * 0.4) * S)})`;
          ctx.beginPath();
          ctx.moveTo(x, y + GAP);
          ctx.quadraticCurveTo(x + bowV(r, c), y + CELL / 2, x, y + CELL - GAP);
          ctx.stroke();
        }
      }
    }
  }

  function tick() {
    // Smooth the mouse position toward target so glow & walker-bias don't snap
    if (mouseTargetX > 0) {
      mouseX += (mouseTargetX - mouseX) * 0.18;
      mouseY += (mouseTargetY - mouseY) * 0.18;
    }
    updateWalkers();
    decay();
    render();
    setTimeout(tick, 60); // ~16fps
  }

  resize();
  window.addEventListener('resize', resize);
  window.addEventListener('load', resize);
  new ResizeObserver(resize).observe(document.body);
  for (let i = 0; i < WALKERS; i++) walkers.push(spawnWalker());
  tick();

  // ── HDMI glitch effect ───────────────────────
  const glitchCvs = document.getElementById('glitch-canvas') as HTMLCanvasElement;
  const glitchCtx = glitchCvs.getContext('2d')!;

  const GLITCH_DURATION = 100;
  const BASE_GLITCH_CHANCE = 0.01;
  const MAX_GLITCH_CHANCE = 0.3;
  const FREQUENCY_GROWTH_TIME = 60000;

  interface Glitch { x: number; y: number; end: number; }
  const activeGlitches: Glitch[] = [];
  const startTime = performance.now();

  function getGlitchColor(): string { return isDark() ? '#00CCCC' : '#008B8B'; }
  function getCurrentGlitchChance(): number {
    const elapsed = performance.now() - startTime;
    return BASE_GLITCH_CHANCE + (MAX_GLITCH_CHANCE - BASE_GLITCH_CHANCE) * Math.min(1, elapsed / FREQUENCY_GROWTH_TIME);
  }
  function renderGlitches(): void {
    const now = performance.now();
    for (let i = activeGlitches.length - 1; i >= 0; i--) {
      if (now >= activeGlitches[i].end) activeGlitches.splice(i, 1);
    }
    glitchCtx.clearRect(0, 0, glitchCvs.width, glitchCvs.height);
    glitchCtx.fillStyle = getGlitchColor();
    for (const g of activeGlitches) {
      glitchCtx.fillRect(g.x + (Math.random() - 0.5) * 2, g.y + (Math.random() - 0.5) * 2, 2, 2);
    }
  }
  function resizeGlitch() { glitchCvs.width = window.innerWidth; glitchCvs.height = window.innerHeight; }
  resizeGlitch();
  window.addEventListener('resize', resizeGlitch);
  function tickGlitch(): void {
    if (Math.random() < getCurrentGlitchChance()) {
      activeGlitches.push({ x: Math.random() * window.innerWidth, y: Math.random() * window.innerHeight, end: performance.now() + GLITCH_DURATION });
    }
    renderGlitches();
    requestAnimationFrame(tickGlitch);
  }
  tickGlitch();

  // ── Film grain overlay ───────────────────────
  const grainCvs = document.getElementById('grain-canvas') as HTMLCanvasElement;
  const grainCtx = grainCvs.getContext('2d')!;

  const BUF = 512;
  const buf = document.createElement('canvas');
  buf.width = buf.height = BUF;
  const bCtx = buf.getContext('2d')!;
  const img = bCtx.createImageData(BUF, BUF);

  function resizeGrain() { grainCvs.width = window.innerWidth; grainCvs.height = window.innerHeight; }
  resizeGrain();
  window.addEventListener('resize', resizeGrain);

  function tickGrain() {
    const d = img.data;
    for (let i = 0; i < d.length; i += 4) {
      const v = (Math.random() * 255) | 0;
      d[i] = d[i+1] = d[i+2] = v;
      d[i+3] = 255;
    }
    bCtx.putImageData(img, 0, 0);
    grainCtx.drawImage(buf, 0, 0, grainCvs.width, grainCvs.height);
    setTimeout(tickGrain, 80);
  }
  tickGrain();
</script>
