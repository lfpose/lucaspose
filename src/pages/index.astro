---
import Base from '../layouts/Base.astro';
import TitleRow from '../components/TitleRow.astro';
import MailGrid from '../components/MailGrid.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Lucas Pose" description="Lucas Pose, software engineer in Santiago, Chile.">
  <TitleRow level="h1" size={36} variant="eye">
    <h1 class="lang-en">Hi, I'm Lucas.</h1>
    <h1 class="lang-es">Hola, soy Lucas.</h1>
  </TitleRow>

  <p class="ticker lang-en">
    <span class="ticker-label">[now]</span>
    <span
      class="ticker-text"
      data-phrases='["building data-intensive UIs","shipping React at Inform","exploring AI agents","in Santiago, Chile"]'
    ></span>
  </p>
  <p class="ticker lang-es">
    <span class="ticker-label">[ahora]</span>
    <span
      class="ticker-text"
      data-phrases='["construyendo UIs de datos","con React en Inform","explorando agentes de IA","en Santiago, Chile"]'
    ></span>
  </p>

  <p class="lang-en">
    I'm a software engineer based in Santiago, Chile. I work at Inform,
    building the front-end of a data-intensive logistics product in React
    and TypeScript. I take ownership of the code at the intersection of
    business logic and the web app, with a constant eye on performance.
  </p>
  <p class="lang-es">
    Soy ingeniero de software en Santiago, Chile. Trabajo en Inform,
    construyendo el front-end de un producto de logística intensivo en datos
    con React y TypeScript. Me enfoco en la intersección entre la lógica de
    negocio y la aplicación web, con especial atención al rendimiento.
  </p>

  <p class="lang-en">
    Outside of work I'm currently deep into autonomous software development
    and AI agentic tooling.
  </p>
  <p class="lang-es">
    Fuera del trabajo estoy profundizando en el desarrollo autónomo de software
    y herramientas de agentes IA.
  </p>

  <TitleRow level="h2" variant="chess">
    <h2 class="lang-en">Interests</h2>
    <h2 class="lang-es">Intereses</h2>
  </TitleRow>

  <ul class="lang-en">
    <li>Chess.</li>
    <li>Climbing.</li>
    <li>RTS games (on screen).</li>
    <li>Guitar (a bit abandoned).</li>
  </ul>
  <ul class="lang-es">
    <li>Ajedrez.</li>
    <li>Escalada.</li>
    <li>Juegos RTS (en pantalla).</li>
    <li>Guitarra (un poco abandonada).</li>
  </ul>

  <TitleRow level="h2" variant="compass">
    <h2 class="lang-en">Elsewhere</h2>
    <h2 class="lang-es">En la red</h2>
  </TitleRow>
  <ul>
    <li><a href="https://github.com/lfpose">GitHub</a></li>
  </ul>

  <p class="lang-en">
    See <a href={`${base}now`}>what I'm working on now</a>.
  </p>
  <p class="lang-es">
    Ver <a href={`${base}now`}>en qué estoy trabajando ahora</a>.
  </p>

  <TitleRow level="h2" variant="mail">
    <h2 class="lang-en">Reach me</h2>
    <h2 class="lang-es">Contacto</h2>
  </TitleRow>
  <MailGrid />
</Base>
